{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":dependencyDashboard"
  ],
  "labels": [
    "dependencies"
  ],
  "packageRules": [
    {
      "description": "Auto-merge all non-major updates",
      "matchUpdateTypes": [
        "minor",
        "patch",
        "pin",
        "digest",
        "bump"
      ],
      "automerge": true
    },
    {
      "description": "Never auto-merge major updates",
      "matchUpdateTypes": [
        "major"
      ],
      "automerge": false
    }
  ]
}
